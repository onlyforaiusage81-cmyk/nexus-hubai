{
  "version": 2,
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/portal", "destination": "/api/portal" },
    { "source": "/tools/roadmap-creator", "destination": "/api/tools/roadmap-creator" },
    { "source": "/tools/ramp-up-planner", "destination": "/api/tools/ramp-up-planner" },
    { "source": "/tools/ybr-studio", "destination": "/api/tools/ybr-studio" },
    { "source": "/tools/ai-quiz-portal", "destination": "/api/tools/ai-quiz-portal" },
    { "source": "/admin", "destination": "/api/admin" },
    { "source": "/admin-login", "destination": "/admin-login.html" }
  ],
  "functions": {
    "api/tools/[slug].js": { "includeFiles": "api/_tools/**" }
  }
}
